#!/usr/bin/env bash
# Re-runs whenever any of the package manifests change (because chezmoi
# hashes the rendered script content).
#
# Brewfile  sha256: {{ joinPath .chezmoi.workingTree "packages" "Brewfile"  | include | sha256sum }}
# apt.txt   sha256: {{ joinPath .chezmoi.workingTree "packages" "apt.txt"   | include | sha256sum }}
# dnf.txt   sha256: {{ joinPath .chezmoi.workingTree "packages" "dnf.txt"   | include | sha256sum }}
# install   sha256: {{ joinPath .chezmoi.workingTree "packages" "install.sh" | include | sha256sum }}

set -uo pipefail
# Don't abort the whole `chezmoi apply` if a single tool's installer
# misbehaves. The dotfiles getting written matters more than every last
# extra being installed; the user can re-run `packages/install.sh`
# afterwards to investigate.
"{{ .chezmoi.workingTree }}/packages/install.sh" || \
  echo "! packages/install.sh exited non-zero — continuing with chezmoi apply"
