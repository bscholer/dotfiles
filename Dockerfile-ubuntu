FROM ubuntu:latest

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -y \
 && apt-get install -y --no-install-recommends \
      sudo curl ca-certificates git zsh passwd \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /root

# Copy the whole repo in so chezmoi can use it as a local source instead of
# cloning from GitHub (lets us test uncommitted changes).
COPY . /root/.dotfiles

# Install chezmoi, then init from the local repo and apply.
RUN curl -fsSL https://get.chezmoi.io | sh -s -- -b /usr/local/bin \
 && chezmoi init --apply --source=/root/.dotfiles

CMD ["/usr/bin/zsh"]
